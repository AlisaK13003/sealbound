    "stranger_flavor_a": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "Tavern is busy today. Means people are hungry and alive. I call that a win."
    },
    "stranger_flavor_b": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "If someone starts a shouting match before lunch, I am charging them extra."
    },
    "stranger_branch": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "You look like you have been running around all day. What do you need?",
      "choices": [
        {
          "text": "A meal sounds good. Thanks.",
          "action": "bond_good",
          "bond_delta": 15,
          "next": "stranger_good"
        },
        {
          "text": "Just a minute to rest.",
          "action": "bond_neutral",
          "bond_delta": 5,
          "next": "stranger_neutral"
        },
        {
          "text": "Nothing from you.",
          "action": "bond_bad",
          "bond_delta": -10,
          "next": "stranger_bad"
        }
      ]
    },
    "stranger_good": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "smile",
      "text": "That is what I like to hear. Sit down."
    },
    "stranger_neutral": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "Then take one. No shame in breathing."
    },
    "stranger_bad": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "sad",
      "text": "Suit yourself. Offer stands anyway."
    },
    "acquainted_flavor_a": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "I broke up an argument over soup this morning. Soup. People are amazing."
    },
    "acquainted_flavor_b": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "Orion said he was here for the food again. Sure he was."
    },
    "acquainted_branch": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "Be honest. Is the tavern too loud?",
      "choices": [
        {
          "text": "It feels alive. I like it.",
          "action": "bond_good",
          "bond_delta": 15,
          "next": "acquainted_good"
        },
        {
          "text": "Sometimes, but it is welcoming.",
          "action": "bond_neutral",
          "bond_delta": 5,
          "next": "acquainted_neutral"
        },
        {
          "text": "It is exhausting.",
          "action": "bond_bad",
          "bond_delta": -10,
          "next": "acquainted_bad"
        }
      ]
    },
    "acquainted_good": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "smile",
      "text": "Exactly. A little noise means people still have some fight in them."
    },
    "acquainted_neutral": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "Fair. I can work with welcoming."
    },
    "acquainted_bad": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "sad",
      "text": "Yeah. It can be. I know."
    },
    "warmed_flavor_a": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "I made too much stew again. That is not a problem. That is planning."
    },
    "warmed_flavor_b": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "Some days I think this place runs on garlic, gossip, and stubbornness."
    },
    "warmed_branch": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "People keep telling me to slow down. You agree with them?",
      "choices": [
        {
          "text": "Yes. You deserve rest too.",
          "action": "bond_good",
          "bond_delta": 15,
          "next": "warmed_good"
        },
        {
          "text": "Maybe sometimes.",
          "action": "bond_neutral",
          "bond_delta": 5,
          "next": "warmed_neutral"
        },
        {
          "text": "You are fine. Keep going.",
          "action": "bond_bad",
          "bond_delta": -10,
          "next": "warmed_bad"
        }
      ]
    },
    "warmed_good": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "smile",
      "text": "Hah. Hard to argue when you say it like that."
    },
    "warmed_neutral": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "Sometimes I can do. Probably."
    },
    "warmed_bad": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "sad",
      "text": "That is what I usually tell myself."
    },
    "kindred_flavor_a": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "After closing, the tavern gets so quiet I can hear the floor settle."
    },
    "kindred_flavor_b": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "I like taking care of people. I just forget it is allowed to go both ways."
    },
    "kindred_branch": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "If I ever look like I am about to push past empty, what should you do?",
      "choices": [
        {
          "text": "Make you sit down and eat.",
          "action": "bond_good",
          "bond_delta": 15,
          "next": "kindred_good"
        },
        {
          "text": "Ask if you need help.",
          "action": "bond_neutral",
          "bond_delta": 5,
          "next": "kindred_neutral"
        },
        {
          "text": "Let you handle it.",
          "action": "bond_bad",
          "bond_delta": -10,
          "next": "kindred_bad"
        }
      ]
    },
    "kindred_good": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "smile",
      "text": "Good answer. Annoying, but good."
    },
    "kindred_neutral": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "I might grumble. Ask anyway."
    },
    "kindred_bad": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "sad",
      "text": "That is the easy answer. Not always the right one."
    },
    "bound_flavor_a": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "The place is yours too, you know. You do not have to wait for an invitation."
    },
    "bound_flavor_b": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "I kept the kitchen open a little late. Figured you might come by."
    },
    "bound_branch": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "I am trying to get better at letting people show up for me.",
      "choices": [
        {
          "text": "I am here. Let me.",
          "action": "bond_good",
          "bond_delta": 15,
          "next": "bound_good"
        },
        {
          "text": "That takes practice.",
          "action": "bond_neutral",
          "bond_delta": 5,
          "next": "bound_neutral"
        },
        {
          "text": "You should not need that.",
          "action": "bond_bad",
          "bond_delta": -10,
          "next": "bound_bad"
        }
      ]
    },
    "bound_good": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "smile",
      "text": "Yeah. I know. Thanks, bud."
    },
    "bound_neutral": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "neutral",
      "text": "Practice I can do."
    },
    "bound_bad": {
      "speaker": "Lyra",
      "portrait_sheet": "res://assets/characters/lyra/Lyra_portraits.png",
      "portrait_frame": "sad",
      "text": "Maybe not. Still does not mean I never do."
    }
  }
