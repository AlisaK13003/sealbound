; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[accessibility]

general/accessibility_driver="dummy"

[application]

config/name="Sealbound"
run/main_scene="uid://dm0c2qg03a00n"
config/features=PackedStringArray("4.7", "Forward Plus")
run/max_fps="120"
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://bnmrflx035ys"

[autoload]

Fade="*uid://bp4nraurt5ifw"
GlobalCombatInformation="*uid://bba2tvdjwats"
Global="*uid://c8yegl8nrw5mx"
AreaStateManager="*uid://bp2deesr31fop"
DialogueSystem="*res://GUI/dialogue_system/dialogue_system.tscn"
AudioManager="*uid://d1p48eva8ookp"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"
window/vsync/vsync_mode=true

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[file_customization]

folder_colors={
"res://assets/Audio/": "pink",
"res://assets/Resources/Interactables/Shops/": "yellow",
"res://assets/tile sheets/Move Sprites/": "red"
}

[global_group]

3D_Player=""
Ground=""
Walls=""
Building_Ground=""
Overworld_Player=""

[gui]

common/snap_controls_to_pixels=false
theme/default_font_multichannel_signed_distance_field=true
theme/custom_font="uid://bpnykjvtqplb2"

